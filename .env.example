# Copy to .env (same directory as docker-compose.yml) before running
# `docker compose up`. Docker Compose reads .env automatically for ${VAR}
# substitution in docker-compose.yml. DATABASE_URL is NOT set here — the
# backend container builds it itself from the Postgres vars below, pointed
# at the "postgres" service by Docker's internal DNS.
#
# The automation/ pipeline has its own separate .env (automation/.env.example)
# since it isn't part of this docker-compose stack — see docs/DEPLOYMENT.md.

# --- Database ---
POSTGRES_USER=yemekteyiz
POSTGRES_PASSWORD=changeme
POSTGRES_DB=yemekteyiz

# --- Backend ---
# Generate a real one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme

# Optional: if both are set, an admin account is created on first backend
# startup (skipped if one with this username already exists).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
