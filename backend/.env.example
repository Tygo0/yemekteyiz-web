# Local development defaults — no Postgres install required.
# SQLite needs nothing else running; the whole database is one file
# (backend/dev.db) that appears the first time you run `flask db upgrade`.
DATABASE_URL=sqlite:///dev.db

FLASK_APP=wsgi.py
FLASK_ENV=development
JWT_SECRET_KEY=dev-secret-change-me

# Used by seed.py to create your first admin login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# --- Optional: switch to Postgres instead of SQLite ---
# Uncomment the line below (and comment out the SQLite one above) if you'd
# rather run against a real local Postgres instance you've already installed
# and started yourself:
# DATABASE_URL=postgresql://yemekteyiz:changeme@localhost:5432/yemekteyiz
